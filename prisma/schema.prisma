generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String         @unique
  passwordHash  String
  role          RoleCode
  phone         String?
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  allocations   Allocation[]   @relation("AllocationAssignedBy")
  auditLogs     AuditLog[]     @relation("UserAuditLogs")
  customers     Customer[]     @relation("CustomerSalesExecutive")
  notes         CustomerNote[]
  notifications Notification[] @relation("UserNotifications")
  requirements  Requirement[]  @relation("RequirementSalesExecutive")
}

model Customer {
  id               Int            @id @default(autoincrement())
  salesExecutiveId Int
  firstName        String
  lastName         String
  email            String?
  phone            String?
  city             String?
  state            String?
  country          String?
  customerTier     String?
  remarks          String?        @db.Text
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  allocations      Allocation[]   @relation("CustomerAllocations")
  salesExecutive   User           @relation("CustomerSalesExecutive", fields: [salesExecutiveId], references: [id])
  notes            CustomerNote[]
  requirements     Requirement[]

  @@index([salesExecutiveId])
}

model CustomerNote {
  id              Int      @id @default(autoincrement())
  customerId      Int
  createdByUserId Int
  note            String   @db.Text
  createdAt       DateTime @default(now())
  createdByUser   User     @relation(fields: [createdByUserId], references: [id])
  customer        Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdByUserId], map: "CustomerNote_createdByUserId_fkey")
}

model Brand {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  slug            String           @unique
  isActive        Boolean          @default(true)
  externalId      String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  models          Model[]
  requirements    Requirement[]
  stockItems      StockItem[]
  watchReferences WatchReference[]
}

model Model {
  id              Int              @id @default(autoincrement())
  brandId         Int
  name            String
  slug            String
  collectionName  String?
  genderCategory  String?
  externalId      String?          @unique
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  brand           Brand            @relation(fields: [brandId], references: [id])
  requirements    Requirement[]
  stockItems      StockItem[]
  watchReferences WatchReference[]

  @@unique([brandId, name])
  @@unique([brandId, slug])
  @@index([brandId])
}

model WatchReference {
  id                  Int                  @id @default(autoincrement())
  brandId             Int
  modelId             Int?
  referenceNumber     String
  displayName         String
  description         String?              @db.LongText
  movement            String?
  caseMaterial        String?
  dialColor           String?
  braceletMaterial    String?
  caseSizeMm          Decimal?             @db.Decimal(8, 2)
  waterResistanceM    Int?
  productionYearStart Int?
  productionYearEnd   Int?
  msrpUsd             Decimal?             @db.Decimal(12, 2)
  currencyCode        String?
  imageUrl            String?
  externalId          String?              @unique
  isActive            Boolean              @default(true)
  lastSyncedAt        DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  requirements        Requirement[]
  stockItems          StockItem[]
  brand               Brand                @relation(fields: [brandId], references: [id])
  model               Model?               @relation(fields: [modelId], references: [id])
  specs               WatchReferenceSpec[]

  @@unique([modelId, referenceNumber])
  @@index([brandId])
  @@index([modelId])
}

model WatchReferenceSpec {
  id               Int            @id @default(autoincrement())
  watchReferenceId Int
  specKey          String
  specValue        String         @db.Text
  watchReference   WatchReference @relation(fields: [watchReferenceId], references: [id])

  @@index([watchReferenceId])
}

model StockItem {
  id               Int             @id @default(autoincrement())
  brandId          Int
  modelId          Int
  watchReferenceId Int?
  serialNumber     String          @unique
  storeSku         String?
  dateReceived     DateTime?
  purchaseCost     Decimal?        @db.Decimal(12, 2)
  currentStatus    StockItemStatus @default(AVAILABLE)
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  allocations      Allocation[]
  brand            Brand           @relation(fields: [brandId], references: [id])
  model            Model           @relation(fields: [modelId], references: [id])
  watchReference   WatchReference? @relation(fields: [watchReferenceId], references: [id])

  @@index([brandId])
  @@index([modelId])
  @@index([watchReferenceId])
}

model Requirement {
  id               Int               @id @default(autoincrement())
  customerId       Int
  salesExecutiveId Int
  brandId          Int
  modelId          Int?
  watchReferenceId Int?
  priorityRank     Int?
  status           RequirementStatus @default(WAITING)
  notes            String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  allocations      Allocation[]
  brand            Brand             @relation(fields: [brandId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id])
  model            Model?            @relation(fields: [modelId], references: [id])
  salesExecutive   User              @relation("RequirementSalesExecutive", fields: [salesExecutiveId], references: [id])
  watchReference   WatchReference?   @relation(fields: [watchReferenceId], references: [id])

  @@index([customerId])
  @@index([salesExecutiveId])
  @@index([brandId])
  @@index([modelId])
  @@index([watchReferenceId])
}

model Allocation {
  id               Int              @id @default(autoincrement())
  requirementId    Int
  customerId       Int
  stockItemId      Int
  assignedByUserId Int
  assignedAt       DateTime
  expiresAt        DateTime
  status           AllocationStatus @default(ACTIVE)
  remarks          String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  assignedByUser   User             @relation("AllocationAssignedBy", fields: [assignedByUserId], references: [id])
  customer         Customer         @relation("CustomerAllocations", fields: [customerId], references: [id])
  requirement      Requirement      @relation(fields: [requirementId], references: [id])
  stockItem        StockItem        @relation(fields: [stockItemId], references: [id])

  @@index([status, expiresAt])
  @@index([requirementId])
  @@index([customerId])
  @@index([stockItemId])
  @@index([assignedByUserId], map: "Allocation_assignedByUserId_fkey")
}

model CatalogSyncRun {
  id          Int        @id @default(autoincrement())
  sourceCode  String
  runType     String
  status      SyncStatus
  startedAt   DateTime
  endedAt     DateTime?
  summaryJson Json?
  errorLog    String?    @db.LongText
}

model EnrichmentRunState {
  id              Int      @id @default(autoincrement())
  jobName         String   @unique
  lastReferenceId Int?
  dailyQuota      Int      @default(180)
  usedToday       Int      @default(0)
  quotaDate       DateTime
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model Notification {
  id        Int                @id @default(autoincrement())
  userId    Int?
  type      String
  title     String
  message   String             @db.Text
  link      String?
  status    NotificationStatus @default(UNREAD)
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User?              @relation("UserNotifications", fields: [userId], references: [id])

  @@index([userId, status])
  @@index([type, createdAt])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  entityType  String
  entityId    String
  action      String
  actorUserId Int?
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation("UserAuditLogs", fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

enum RoleCode {
  ADMIN
  MANAGER
  SALES_EXECUTIVE
}

enum RequirementStatus {
  WAITING
  ASSIGNED
  SOLD
  CANCELLED
}

enum StockItemStatus {
  AVAILABLE
  ASSIGNED
  SOLD
  CANCELLED
  HOLD_EXPIRED
}

enum AllocationStatus {
  ACTIVE
  SOLD
  EXPIRED
  CANCELLED
}

enum SyncStatus {
  STARTED
  SUCCESS
  FAILED
  PARTIAL
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
}
